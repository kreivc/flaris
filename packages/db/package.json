{
  "name": "@flaris/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "DRIZZLE_LOCAL=true drizzle-kit migrate",
    "db:migrate:prod": "drizzle-kit migrate",
    "db:studio:local": "DRIZZLE_LOCAL=true drizzle-kit studio",
    "db:studio:prod": "drizzle-kit studio",
    "check-types": "tsc -b"
  },
  "dependencies": {
    "@flaris/env": "workspace:*",
    "@libsql/client": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "libsql": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@flaris/config": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5"
  }
}
