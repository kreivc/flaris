{
  "name": "@flaris/auth",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc -b",
    "generate:schema": "dotenv -e ../../apps/server/.env -- pnpm dlx @better-auth/cli@latest generate --config ./src/index.ts --output ../db/src/schema/auth.ts --yes"
  },
  "dependencies": {
    "@flaris/db": "workspace:*",
    "@flaris/env": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@flaris/config": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "typescript": "^5"
  }
}
